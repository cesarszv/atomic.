---
import logo from '../assets/logo.png';

interface Props {
  lang?: string;
}

const { lang = 'en-US' } = Astro.props;
const isEs = lang.startsWith('es');
const baseUrl = import.meta.env.BASE_URL;
---

<header class="site-header" aria-label={isEs ? "Encabezado del sitio" : "Site header"}>
  <a class="brand" href={isEs ? "es.html" : "index.html"} aria-label={isEs ? "Inicio de ATOMIC" : "ATOMIC home"}>
    <img src={logo.src} alt="" width="40" height="40" />
    <span translate="no">ATOMIC</span>
  </a>
  <nav class="site-nav" aria-label={isEs ? "Navegación principal" : "Primary navigation"}>
    <a href="#idea">Idea</a>
    <a href="#principles">{isEs ? "Principios" : "Principles"}</a>
    <a href="#access">{isEs ? "Acceso" : "Access"}</a>
    <div class="language-switcher" role="group" aria-label={isEs ? "Idioma" : "Language"}>
      <a aria-current={!isEs ? "page" : undefined} lang="en-US" href="index.html">EN</a>
      <a aria-current={isEs ? "page" : undefined} lang="es-419" href="es.html">ES</a>
    </div>
  </nav>
</header>
